# Default job application automation settings for hh.ru
#
# This is an example configuration file for the hh-apply CLI tool.
# Copy this file to .lenv and uncomment/modify the options you want to use.
#
# The .lenv file uses Links Notation format with ': ' (colon-space) separator.
# Configuration priority (highest to lowest):
# 1. CLI arguments (e.g., --port 8080)
# 2. Environment variables (e.g., export PORT=8080)
# 3. .lenv file (this file when renamed to .lenv)
#
# For more details, see: https://github.com/link-foundation/lino-arguments

# Browser automation engine to use
# Choices: 'playwright' or 'puppeteer'
# Default: playwright
# ENGINE: playwright

# Starting URL for job search
# Default: https://hh.ru/search/vacancy?from=resumelist
# START_URL: https://hh.ru/search/vacancy?resume=YOUR_RESUME_ID&from=resumelist

# Open login page and wait for manual authentication before proceeding
# Default: false
# MANUAL_LOGIN: true

# Path to user data directory for persistent session storage
# If not set, defaults to ~/.hh-automation/{engine}-data
# USER_DATA_DIR: ./user-data

# Base interval in seconds between job application button clicks
# The app also adds a random 1-5 second delay to each wait
# Default: 20 (seconds)
# JOB_APPLICATION_INTERVAL: 20

# Custom message to send with job application
# If not set, uses MESSAGE_FILE or the default cover letter from config.mjs
# MESSAGE: Здравствуйте, я заинтересован в данной вакансии...

# Path to a UTF-8 text file with a multi-line application message
# Used when MESSAGE is not set
# MESSAGE_FILE: ./message.txt

# Enable verbose logging for debugging
# Default: false
# VERBOSE: true

# Auto-submit vacancy response forms when all questions are answered
# Default: false (manual review recommended for safety)
# AUTO_SUBMIT_VACANCY_RESPONSE_FORM: true

# Skip vacancies that require questionnaire fields beyond the cover letter
# Default: false
# IGNORE_VACANCIES_WITH_QUESTIONNAIRE: true
